# WalletConnect Project ID
# Get your project ID from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Public site URL used for share links / OG image previews (required for X/Twitter cards)
# Example: https://genesis.streak.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API Configuration
# Example: https://streak-api.duckdns.org
NEXT_PUBLIC_BACKEND_API_URL=https://streak-api.duckdns.org

# API Configuration (Optional - Backend uses hardcoded key for POC)
THE_GRAPH_API_KEY=06fa2f6386af468ecdd4be9ec45650f1
